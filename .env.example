POSTGRES_DB=hospiq
POSTGRES_USER=hospiq
POSTGRES_PASSWORD=          # Run: openssl rand -base64 24
DATABASE_URL=postgres://hospiq:<POSTGRES_PASSWORD>@postgres:5432/hospiq
REDIS_PASSWORD=             # Run: openssl rand -base64 16
REDIS_URL=redis://:<REDIS_PASSWORD>@redis:6379
JWT_SECRET=                 # Run: openssl rand -base64 32
JWT_EXPIRY=1h
REFRESH_TOKEN_EXPIRY=7d
ENCRYPTION_KEY=             # Run: openssl rand -hex 32
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3
WHISPER_URL=http://whisper:8080
GRAFANA_PASSWORD=admin
LOKI_URL=http://loki:3100
NODE_ENV=development
API_PORT=4000
FRONTEND_URL=http://localhost:80
CORS_ORIGINS=http://localhost:80,http://localhost:3000
WORKER_CONCURRENCY=5
MAX_RETRIES=3
CIRCUIT_BREAKER_THRESHOLD=3
CIRCUIT_BREAKER_RESET_MS=30000
SLA_LOW=120
SLA_MEDIUM=60
SLA_HIGH=30
SLA_CRITICAL=15
