        SSE["SSE Connection<br/>/api/requests/:id/stream"]
    end

    subgraph Staff["Staff Browser"]
        WS["WebSocket<br/>/ws/dashboard"]
    end

    subgraph API["Elysia API"]
        SSE_Handler["SSE Handler"]
        WS_Handler["WS Handler"]
    end

    subgraph Redis["Redis Pub/Sub"]
