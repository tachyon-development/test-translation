sequenceDiagram
    participant Worker
    participant PG as PostgreSQL
    participant Registry as Adapter Registry
    participant Adapter as Integration Adapter
    participant External as External API

    Worker->>PG: Workflow event fires
    Worker->>PG: SELECT matching integrations

    loop For each integration
        Worker->>Registry: getAdapter(provider)
        Registry-->>Worker: adapter instance
        Worker->>Adapter: buildPayload(workflow, mappings)
        Adapter-->>Worker: mapped payload
        Worker->>External: POST payload
        alt Success
            Worker->>PG: INSERT event (success)
        else Failure
            Worker->>PG: INSERT event (failed)
            Worker->>Worker: Re-enqueue with backoff
        end
    end
